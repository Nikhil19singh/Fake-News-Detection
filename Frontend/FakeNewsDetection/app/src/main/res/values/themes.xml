<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ✅ BASE APP THEME -->
    <style name="Base.Theme.FakeNewsDetection" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/purple_700</item>
        <item name="android:windowBackground">@color/purple_700</item>
    </style>

    <!-- ✅ MAIN APP THEME -->
    <style name="Theme.FakeNewsDetection" parent="Base.Theme.FakeNewsDetection"/>

    <!-- ✅ NO ACTION BAR THEME -->
    <style name="Theme.FakeNewsDetection.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- ✅ ANDROID 12+ SPLASH THEME (NO ANDROID LOGO, NO DELAY) -->
    <style name="Theme.FakeNewsDetection.Splash" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- ✅ Replace system splash instantly -->
        <item name="android:windowSplashScreenBackground">@drawable/splash_gradient_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_news</item>

        <!-- ✅ Remove system animation delay -->
        <item name="android:windowSplashScreenAnimationDuration">0</item>

        <!-- ✅ Fullscreen -->
        <item name="android:windowFullscreen">true</item>

        <!-- ✅ No Action Bar -->
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

    </style>

</resources>
